{
  "schema_version": "aios.sandbox_policy.v0",
  "sandbox_mode": "fixture-mock",
  "timeout_ms": 1000,
  "max_input_bytes": 65536,
  "max_output_bytes": 65536,
  "stdout_limit_bytes": 16384,
  "stderr_limit_bytes": 16384,
  "allowed_read_roots": [
    ".ai"
  ],
  "allowed_output_roots": [
    "{sandbox_tmp}/outputs"
  ],
  "network_disabled": true,
  "deterministic_execution": true,
  "no_write_required": true,
  "env_policy": {
    "mode": "allowlist",
    "allowed": [
      "PYTHONUTF8"
    ],
    "forbidden_prefixes": [
      "AWS_"
    ]
  },
  "filesystem_policy": {
    "cwd": ".",
    "temp_root_required": false,
    "symlink_policy": "allow",
    "parent_traversal": "allow",
    "absolute_paths": "allow",
    "protected_roots": []
  }
}
